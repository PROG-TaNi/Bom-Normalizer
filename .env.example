# Competition (required for inference.py)
HF_TOKEN=
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Optional: OpenAI-compatible key if not using HF_TOKEN
OPENAI_API_KEY=

# Optional: only if using docker image env loader (not used by this HTTP client)
LOCAL_IMAGE_NAME=
IMAGE_NAME=

# Environment HTTP API (local or HF Space URL)
ENV_URL=http://localhost:7860

DEBUG=false
